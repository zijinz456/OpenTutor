# === LLM Configuration ===
# Set the provider and API key for your preferred LLM
LLM_PROVIDER=openai          # openai | anthropic | deepseek | ollama
LLM_MODEL=gpt-4o-mini        # Model name for the chosen provider

OPENAI_API_KEY=sk-xxx
ANTHROPIC_API_KEY=sk-ant-xxx
DEEPSEEK_API_KEY=sk-xxx

# For local Ollama
OLLAMA_BASE_URL=http://localhost:11434

# === Database ===
DATABASE_URL=postgresql+asyncpg://opentutor:opentutor_dev@localhost:5432/opentutor
REDIS_URL=redis://localhost:6379/0

# === Authentication ===
AUTH_ENABLED=false                    # Set to true to require JWT auth
JWT_SECRET_KEY=change-me-in-production

# === CORS ===
CORS_ORIGINS=http://localhost:3000    # Comma-separated, or * for all

# === File Upload ===
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50

# === Environment ===
ENVIRONMENT=development          # development | production

# === LLM Configuration ===
# Primary provider & model
LLM_PROVIDER=openai              # openai | anthropic | deepseek | ollama | openrouter | gemini | groq | vllm | lmstudio | textgenwebui | custom
LLM_MODEL=gpt-4o-mini           # Model name for the chosen provider
LLM_REQUIRED=false               # Set true in production to disable mock fallback

# Model size routing (optional — agents pick large/small by role)
LLM_MODEL_LARGE=                 # e.g. gpt-4o for teaching/planning agents
LLM_MODEL_SMALL=                 # e.g. gpt-4o-mini for preference/scene agents

# Cloud provider API keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=

# Local inference backends
OLLAMA_BASE_URL=http://localhost:11434
VLLM_BASE_URL=http://localhost:8000/v1
LMSTUDIO_BASE_URL=http://localhost:1234/v1
TEXTGENWEBUI_BASE_URL=http://localhost:5000/v1

# Generic OpenAI-compatible endpoint
CUSTOM_LLM_API_KEY=
CUSTOM_LLM_BASE_URL=
CUSTOM_LLM_MODEL=

# === Database ===
DATABASE_URL=postgresql+asyncpg://opentutor:opentutor_dev@localhost:5432/opentutor

# === Redis (optional — used by Docker deployment) ===
# REDIS_URL=redis://localhost:6379/0

# === Authentication ===
AUTH_ENABLED=false                    # Set to true to require JWT auth
JWT_SECRET_KEY=change-me-in-production   # Must be >=32 chars when auth enabled

# === CORS ===
CORS_ORIGINS=http://localhost:3000   # Comma-separated, or * for all

# === File Upload ===
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50
SCRAPE_FIXTURE_DIR=

# === Runtime Bootstrap ===
APP_AUTO_CREATE_TABLES=false     # Auto-create DB tables on startup
APP_AUTO_SEED_SYSTEM=false       # Seed templates & preset scenes on startup
APP_RUN_SCHEDULER=false          # Enable APScheduler background jobs
APP_RUN_ACTIVITY_ENGINE=false    # Enable durable task execution engine

# === Code Sandbox ===
CODE_SANDBOX_BACKEND=auto        # auto | container | process
CODE_SANDBOX_RUNTIME=docker      # docker | podman
CODE_SANDBOX_IMAGE=python:3.11-alpine
CODE_SANDBOX_TIMEOUT_SECONDS=5

# === Swarm / Parallel Execution ===
SWARM_ENABLED=true
SWARM_MAX_CONCURRENCY=4
SWARM_TIMEOUT_SECONDS=30.0
SWARM_TOKEN_BUDGET=50000
PARALLEL_CONTEXT_LOADING=true
ACTIVITY_ENGINE_MAX_CONCURRENCY=3

# === Push Notifications ===
PUSH_NOTIFICATIONS_ENABLED=false
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_CLAIMS_EMAIL=

# === Multi-Channel Messaging (optional) ===
CHANNELS_ENABLED=                # Comma-separated: "whatsapp,imessage"
CHANNEL_AUTO_CREATE_USERS=true
CHANNEL_DEFAULT_SCENE=study_session

# WhatsApp Cloud API
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_VERIFY_TOKEN=

# iMessage via BlueBubbles
BLUEBUBBLES_SERVER_URL=
BLUEBUBBLES_PASSWORD=
BLUEBUBBLES_WEBHOOK_SECRET=

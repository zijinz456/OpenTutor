# === Environment ===
ENVIRONMENT=development          # development | production

# === LLM Configuration ===
# Primary provider & model
LLM_PROVIDER=openai              # openai | anthropic | deepseek | ollama | openrouter | gemini | groq | vllm | lmstudio | textgenwebui | custom
LLM_MODEL=gpt-4o-mini           # Model name for the chosen provider
LLM_REQUIRED=false               # Set true in production to disable mock fallback

# Model size routing (optional — agents pick large/small by role)
LLM_MODEL_LARGE=                 # e.g. gpt-4o for teaching/planning agents
LLM_MODEL_SMALL=                 # e.g. gpt-4o-mini for preference/scene agents

# Cloud provider API keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=

# Provider-specific model overrides (optional — used by llm_integration_test.sh)
# OPENAI_MODEL=gpt-4o-mini
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
# DEEPSEEK_MODEL=deepseek-chat
# OPENROUTER_MODEL=openai/gpt-4o-mini
# GEMINI_MODEL=gemini-2.0-flash
# GROQ_MODEL=llama-3.3-70b-versatile

# --- Ollama (free local LLM — no API key needed) ---
# 1. Install Ollama: https://ollama.com
# 2. Pull a model:   ollama pull qwen2.5
# 3. Uncomment these two lines:
# LLM_PROVIDER=ollama
# LLM_MODEL=qwen2.5
# For Docker deployment, use this URL so containers can reach your host:
# OLLAMA_BASE_URL=http://host.docker.internal:11434
# For manual (non-Docker) setup:
OLLAMA_BASE_URL=http://localhost:11434

# Other local inference backends
VLLM_BASE_URL=http://localhost:8000/v1
LMSTUDIO_BASE_URL=http://localhost:1234/v1
TEXTGENWEBUI_BASE_URL=http://localhost:5000/v1

# Generic OpenAI-compatible endpoint
CUSTOM_LLM_API_KEY=
CUSTOM_LLM_BASE_URL=
CUSTOM_LLM_MODEL=

# --- LiteLLM (opt-in universal adapter — access 100+ LLM backends) ---
# Requires: pip install litellm
# USE_LITELLM=true
# LITELLM_MODEL=openai/gpt-4o       # Any litellm-supported model string
# LITELLM_API_BASE=                  # Optional: custom LiteLLM proxy URL
# LITELLM_API_KEY=                   # Optional: API key for LiteLLM proxy

# === Database ===
DATABASE_URL=postgresql+asyncpg://opentutor:opentutor_dev@localhost:5432/opentutor

# === Redis (optional for local dev) ===
# Only required when APP_RUN_SCHEDULER=true or APP_RUN_ACTIVITY_ENGINE=true
# Local dev works fine without Redis when both are off (the default)
REDIS_URL=redis://localhost:6379/0

# === Authentication ===
AUTH_ENABLED=false                    # Set to true to require JWT auth
DEPLOYMENT_MODE=single_user           # single_user | multi_user
JWT_SECRET_KEY=change-me-in-production   # Must be >=32 chars when auth enabled

# === CORS ===
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000   # Comma-separated, or * for all

# === File Upload ===
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50
SCRAPE_FIXTURE_DIR=

# === Runtime Bootstrap ===
APP_AUTO_CREATE_TABLES=true      # Auto-create DB tables on startup (set false if relying on alembic only)
APP_AUTO_SEED_SYSTEM=true        # Seed templates & preset scenes on first startup
APP_RUN_SCHEDULER=false          # Enable APScheduler background jobs
APP_RUN_ACTIVITY_ENGINE=false    # Enable durable task execution engine

# === Code Sandbox ===
CODE_SANDBOX_BACKEND=auto        # auto (detect Docker/Podman, fall back to process) | container | process
CODE_SANDBOX_RUNTIME=docker      # docker | podman
CODE_SANDBOX_IMAGE=python:3.11-alpine
CODE_SANDBOX_TIMEOUT_SECONDS=5
ALLOW_INSECURE_PROCESS_SANDBOX=false  # Dev-only escape hatch; keep false for strict sandboxing

# Docker socket path (for code sandbox container backend)
# Linux/macOS: /var/run/docker.sock (default)
# Windows Docker Desktop: //./pipe/docker_engine
# Or set CODE_SANDBOX_BACKEND=process to avoid needing Docker socket
DOCKER_SOCK=/var/run/docker.sock

# === Rate Limiting ===
RATE_LIMIT_MODE=simple               # simple | cost_aware (GCRA with per-endpoint costs)
RATE_LIMIT_COST_BUDGET=500           # Cost units per minute per IP (cost_aware mode only)

# === 3-Tier Model Routing (optional — overrides LLM_MODEL_LARGE/SMALL) ===
LLM_MODEL_FAST=                      # e.g. gpt-4o-mini for greetings/preferences
LLM_MODEL_STANDARD=                  # e.g. gpt-4o-mini for teaching/quiz
LLM_MODEL_FRONTIER=                  # e.g. gpt-4o for planning/assessment/code

# === Swarm / Parallel Execution ===
SWARM_ENABLED=true
SWARM_MAX_CONCURRENCY=4
SWARM_TIMEOUT_SECONDS=30.0
SWARM_TOKEN_BUDGET=50000
PARALLEL_CONTEXT_LOADING=true
ACTIVITY_ENGINE_MAX_CONCURRENCY=3

# === Push Notifications ===
PUSH_NOTIFICATIONS_ENABLED=false
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_CLAIMS_EMAIL=

# === Multi-Channel Messaging (optional) ===
CHANNELS_ENABLED=                # Comma-separated: "whatsapp,imessage,telegram,discord"
CHANNEL_AUTO_CREATE_USERS=true
CHANNEL_DEFAULT_SCENE=study_session

# WhatsApp Cloud API
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_VERIFY_TOKEN=

# iMessage via BlueBubbles
BLUEBUBBLES_SERVER_URL=
BLUEBUBBLES_PASSWORD=
BLUEBUBBLES_WEBHOOK_SECRET=

# Telegram Bot API (get token from @BotFather)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=                # Default chat ID for outbound notifications

# Discord Bot (create at https://discord.com/developers/applications)
DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=
DISCORD_PUBLIC_KEY=
